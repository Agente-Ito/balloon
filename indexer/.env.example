# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call this API.
# Leave empty to allow ALL origins (only safe behind a firewall / on testnet).
# Production example:
#   ALLOWED_ORIGINS=https://celebrations-app.vercel.app,https://grid.lukso.network
ALLOWED_ORIGINS=

# ── Network ───────────────────────────────────────────────────────────────────
CHAIN_ID=4201
RPC_URL=https://rpc.testnet.lukso.network

# ── Contract addresses ────────────────────────────────────────────────────────
# Copy from the output of: npx hardhat run scripts/deploy/deployAll.ts
CELEBRATIONS_BADGE_ADDRESS=0x0000000000000000000000000000000000000000
GREETING_CARD_ADDRESS=0x0000000000000000000000000000000000000000
CELEBRATION_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
CELEBRATIONS_DROP_ADDRESS=0x0000000000000000000000000000000000000000

# Official LUKSO LSP26 FollowerSystem address (same on mainnet and testnet)
LSP26_ADDRESS=0xf01103E5a9909Fc0DBe8166dA7085e0285daDDcA

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file
DB_PATH=./data/celebrations.db

# ── Block range ───────────────────────────────────────────────────────────────
# How many blocks to replay per getLogs call (keep below 10000 for public RPCs)
BLOCK_BATCH_SIZE=2000
