# ── Network ──────────────────────────────────────────────────────────────────
# 42 = LUKSO Mainnet | 4201 = LUKSO Testnet
VITE_CHAIN_ID=4201

# ── Contract addresses ────────────────────────────────────────────────────────
# Set these after running: npx hardhat run scripts/deploy/deployAll.ts --network luksoTestnet
VITE_CELEBRATIONS_BADGE_ADDRESS=0x0000000000000000000000000000000000000000
VITE_GREETING_CARD_ADDRESS=0x0000000000000000000000000000000000000000
VITE_CELEBRATIONS_DELEGATE_ADDRESS=0x0000000000000000000000000000000000000000

# Set these after running the individual deploy scripts:
VITE_CELEBRATION_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
VITE_FOLLOW_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
VITE_DROP_BADGE_ADDRESS=0x0000000000000000000000000000000000000000
VITE_CELEBRATIONS_DROP_ADDRESS=0x0000000000000000000000000000000000000000

# ── Indexer API ───────────────────────────────────────────────────────────────
# URL of the running indexer (default: localhost:3001 in dev)
VITE_INDEXER_URL=http://localhost:3001/api

# ── IPFS proxy ────────────────────────────────────────────────────────────────
# Use the Cloudflare Worker proxy so no Pinata credential is ever shipped to the browser.
VITE_IPFS_PROXY_URL=http://localhost:8787
# Optional: override the default Pinata gateway
# VITE_PINATA_GATEWAY_URL=https://gateway.pinata.cloud
